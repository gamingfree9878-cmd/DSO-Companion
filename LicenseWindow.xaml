<Window x:Class="DSOCompanion.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DSO Companion – Aktivierung"
        Width="720"
        Height="590"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Border Style="{StaticResource CardStyle}" Padding="28">
            <StackPanel>
                <TextBlock Text="🔐 DSO COMPANION"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Lizenz / HWID"
                           FontSize="18"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,26"/>

                <TextBlock Text="HWID dieses PCs"
                           Foreground="{StaticResource MutedBrush}"/>
                <TextBox x:Name="HardwareIdBox"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="16"
                         Margin="0,6,0,6"/>
                <Button Content="HWID kopieren"
                        HorizontalAlignment="Left"
                        Click="CopyHardwareId_OnClick"/>

                <TextBlock Text="Aktivierungscode"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,18,0,0"/>
                <TextBox x:Name="ActivationCodeBox"
                         Height="100"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         Margin="0,6,0,8"/>

                <Button Content="Lizenz aktivieren"
                        Background="{StaticResource AccentBrush}"
                        Height="46"
                        Click="Activate_OnClick"/>

                <Border Background="#0A111C"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,14,0,0">
                    <TextBlock x:Name="StatusText"
                               Text="🔴 Noch nicht aktiviert"
                               Foreground="#FF718A"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>
                </Border>

                <TextBlock Text="DSO Companion · Version 1.5.2.1 · by Mcdead"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
