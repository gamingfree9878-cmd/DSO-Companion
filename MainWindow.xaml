<Window x:Class="DSOCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DSO Companion"
        Width="1450"
        Height="900"
        MinWidth="1150"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="20">
                <TextBlock Text="⚒ DSO Companion"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,24"/>

                <Button x:Name="DashboardButton"
                        Content="🏠 Übersicht"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="DashboardButton_OnClick"/>

                <Button x:Name="CharactersButton"
                        Content="👤 Charaktere &amp; Builds"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="CharactersButton_OnClick"/>

                <Button x:Name="EquipmentButton"
                        Content="⚔ Ausrüstung"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="EquipmentButton_OnClick"/>

                <Button x:Name="GemsButton"
                        Content="💎 Edelsteine"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="GemsButton_OnClick"/>

                <Button x:Name="RunesButton"
                        Content="ᚱ Runen"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="RunesButton_OnClick"/>

                <Button x:Name="JewelsButton"
                        Content="🔷 Juwelen"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="JewelsButton_OnClick"/>

                <Button x:Name="MortisButton"
                        Content="🦴 Mortis / BGH"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="MortisButton_OnClick"/>

                <Button x:Name="VarnokButton"
                        Content="⭐ Varnok"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="VarnokButton_OnClick"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="24"
              Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Charakter:"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="4"/>

                    <ComboBox x:Name="CharacterCombo"
                              Grid.Column="1"
                              DisplayMemberPath="Name"
                              SelectionChanged="CharacterCombo_OnSelectionChanged"/>

                    <Button Grid.Column="2"
                            Content="+ Charakter"
                            Background="{StaticResource AccentBrush}"
                            Click="AddCharacter_OnClick"/>

                    <Button Grid.Column="3"
                            Content="Umbenennen"
                            Click="RenameCharacter_OnClick"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <Button Content="Export"
                                Click="ExportCharacter_OnClick"/>
                        <Button Content="Import"
                                Click="ImportCharacter_OnClick"/>
                        <Button Content="Löschen"
                                Background="{StaticResource DangerBrush}"
                                Click="DeleteCharacter_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="6,10,6,6">

                <!-- Dashboard -->
                <ScrollViewer x:Name="DashboardPage"
                              Background="{StaticResource BackgroundBrush}"
                              Visibility="Visible">
                    <StackPanel Margin="12">
                        <TextBlock Text="Übersicht"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Margin="6,4,6,4"/>

                        <TextBlock Text="Dein DSO-Begleiter auf einen Blick."
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="6,0,6,18"/>

                        <UniformGrid Columns="3">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="👤 Aktiver Charakter"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="DashboardCharacterText"
                                               Foreground="White"
                                               FontSize="25"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="⚔ Aktiver Build"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="DashboardBuildText"
                                               Foreground="White"
                                               FontSize="23"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="📦 Gespeicherte Builds"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="DashboardBuildCountText"
                                               Foreground="White"
                                               FontSize="25"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource CardStyle}" Margin="6,18,6,6">
                            <StackPanel>
                                <TextBlock Text="Willkommen im DSO Companion"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Über das Menü links erreichst du jetzt alle Bereiche. Charaktere, Builds und Ausrüstung sind bereits nutzbar. Die Rechner für Edelsteine, Runen, Juwelen und Mortis werden in den nächsten Versionen auf ihren eigenen Seiten ergänzt."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Characters -->
                <ScrollViewer x:Name="CharactersPage"
                              Background="{StaticResource BackgroundBrush}"
                              Visibility="Collapsed">
                    <StackPanel Margin="12">
                        <TextBlock Text="Charakterverwaltung"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Margin="6,4,6,4"/>

                        <TextBlock Text="Profile, Builds und Ausrüstung werden automatisch lokal gespeichert."
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="6,0,6,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="390"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="👤 Charakterdaten"
                                               Foreground="White"
                                               FontSize="21"
                                               FontWeight="Bold"
                                               Margin="4,0,4,12"/>

                                    <TextBlock Text="Name" Foreground="{StaticResource MutedBrush}" Margin="4"/>
                                    <TextBox x:Name="CharacterNameBox"
                                             TextChanged="CharacterField_OnChanged"/>

                                    <TextBlock Text="Klasse" Foreground="{StaticResource MutedBrush}" Margin="4,10,4,4"/>
                                    <ComboBox x:Name="ClassCombo"
                                              SelectionChanged="CharacterField_OnChanged"/>

                                    <TextBlock Text="Level" Foreground="{StaticResource MutedBrush}" Margin="4,10,4,4"/>
                                    <TextBox x:Name="LevelBox"
                                             TextChanged="CharacterField_OnChanged"/>

                                    <TextBlock Text="Server" Foreground="{StaticResource MutedBrush}" Margin="4,10,4,4"/>
                                    <ComboBox x:Name="ServerCombo"
                                              SelectionChanged="CharacterField_OnChanged"/>

                                    <TextBlock Text="Notizen" Foreground="{StaticResource MutedBrush}" Margin="4,10,4,4"/>
                                    <TextBox x:Name="CharacterNotesBox"
                                             Height="100"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="CharacterField_OnChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="⚔ Builds"
                                               Foreground="White"
                                               FontSize="21"
                                               FontWeight="Bold"
                                               Margin="4,0,4,12"/>

                                    <WrapPanel Grid.Row="1">
                                        <Button Content="+ Build"
                                                Background="{StaticResource AccentBrush}"
                                                Click="AddBuild_OnClick"/>
                                        <Button Content="Umbenennen"
                                                Click="RenameBuild_OnClick"/>
                                        <Button Content="Kopieren"
                                                Click="CopyBuild_OnClick"/>
                                        <Button Content="Löschen"
                                                Background="{StaticResource DangerBrush}"
                                                Click="DeleteBuild_OnClick"/>
                                    </WrapPanel>

                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                Margin="4,8,4,8">
                                        <TextBlock Text="Build-Typ:"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <ComboBox x:Name="BuildTypeCombo"
                                                  Width="180"
                                                  SelectionChanged="BuildTypeCombo_OnSelectionChanged"/>
                                    </StackPanel>

                                    <ListBox x:Name="BuildList"
                                             Grid.Row="3"
                                             DisplayMemberPath="Name"
                                             SelectionChanged="BuildList_OnSelectionChanged"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <UniformGrid Columns="3" Margin="0,10,0,0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="👤 Aktiver Charakter"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="SummaryCharacterText"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="⚔ Klasse &amp; Server"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="SummaryClassText"
                                               Foreground="White"
                                               FontSize="19"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="📦 Builds"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="SummaryBuildCountText"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Equipment -->
                <Grid x:Name="EquipmentPage"
                      Background="{StaticResource BackgroundBrush}"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Ausrüstung des Builds:"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="4"/>
                            <TextBlock x:Name="ActiveBuildHeader"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="8,4"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Ausrüstungsslots"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Margin="4,0,4,12"/>
                                <ListBox x:Name="EquipmentSlotList"
                                         DisplayMemberPath="SlotName"
                                         SelectionChanged="EquipmentSlotList_OnSelectionChanged"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <ScrollViewer>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.ColumnSpan="2"
                                               x:Name="SelectedSlotHeader"
                                               Text="Ausrüstung"
                                               Foreground="White"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Margin="4,0,4,14"/>

                                    <TextBlock Grid.Row="1" Text="Itemname" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="ItemNameBox" Grid.Row="1" Grid.Column="1" TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="2" Text="Gegenstandsstufe" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="ItemLevelBox" Grid.Row="2" Grid.Column="1" TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="3" Text="Basiswerte" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="BaseValuesBox" Grid.Row="3" Grid.Column="1" Height="75"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="4" Text="Verzauberungen" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="EnchantmentsBox" Grid.Row="4" Grid.Column="1" Height="95"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="5" Text="Edelsteine" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="GemsBox" Grid.Row="5" Grid.Column="1" Height="70"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="6" Text="Runen" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="RunesBox" Grid.Row="6" Grid.Column="1" Height="65"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="7" Text="Juwel" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="JewelBox" Grid.Row="7" Grid.Column="1" TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="8" Text="Notizen" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="EquipmentNotesBox" Grid.Row="8" Grid.Column="1" Height="85"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="EquipmentField_OnChanged"/>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Placeholder pages -->
                <ScrollViewer x:Name="GemsPage"
                              Visibility="Collapsed"
                              Background="{StaticResource BackgroundBrush}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Edelsteine"
                                           Foreground="White"
                                           FontSize="30"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Jede Sorte wird unabhängig berechnet."
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="+ Profil"
                                        Background="{StaticResource AccentBrush}"
                                        Click="AddCharacter_OnClick"/>
                                <Button Content="Umbenennen"
                                        Click="RenameCharacter_OnClick"/>
                                <Button Content="Löschen"
                                        Background="{StaticResource DangerBrush}"
                                        Click="DeleteCharacter_OnClick"/>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource CardStyle}"
                                Margin="6,14,6,4">
                            <StackPanel>
                                <TextBlock Text="Maximale Edelsteine auf einen Blick"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Zeigt je Edelsteinart den Bestand der Stufe „Maximal“."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="11"
                                           Margin="0,3,0,9"/>

                                <ItemsControl x:Name="MaximumGemOverviewControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0C1420"
                                                    BorderBrush="#2B374B"
                                                    BorderThickness="1"
                                                    CornerRadius="9"
                                                    Padding="7"
                                                    Margin="3"
                                                    MinWidth="132">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="38"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="34"
                                                            Height="34"
                                                            CornerRadius="6"
                                                            Background="#17130D"
                                                            BorderBrush="#776A4E"
                                                            BorderThickness="1"
                                                            Padding="2">
                                                        <Image Source="{Binding ImagePath, Mode=OneWay}"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding GemName}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center"
                                                               Margin="7,0,5,0"/>
                                                    <Border Grid.Column="2"
                                                            Background="#1B2637"
                                                            BorderBrush="#8061F1"
                                                            BorderThickness="1"
                                                            CornerRadius="7"
                                                            MinWidth="38"
                                                            Padding="7,4">
                                                        <TextBlock Text="{Binding MaximumQuantity, Mode=OneWay}"
                                                                   Foreground="#55D6C2"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <UniformGrid Columns="4" Margin="0,14,0,0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Benötigter Staub"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="GemNeededDustText"
                                               Foreground="#9B7BFF"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Noch fehlender Staub"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="GemMissingDustText"
                                               Foreground="#FF5578"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Benötigtes Gold"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="GemNeededGoldText"
                                               Foreground="#FFD34F"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Noch fehlendes Gold"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="GemMissingGoldText"
                                               Foreground="#FF5578"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource CardStyle}" Margin="6,10,6,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Vorhandener funkelnder Staub"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBox x:Name="OwnedGemDustBox"
                                             TextChanged="GemResource_OnChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Vorhandenes Gold"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBox x:Name="OwnedGoldBox"
                                             TextChanged="GemResource_OnChanged"/>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="Edelsteine leeren"
                                        Background="{StaticResource DangerBrush}"
                                        VerticalAlignment="Bottom"
                                        Margin="8,4"
                                        Click="ClearAllGems_OnClick"/>
                            </Grid>
                        </Border>

                        <Grid Margin="2,6,2,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                            <Button x:Name="GemFilterAllButton"
                                    Content="Alle"
                                    Background="{StaticResource AccentBrush}"
                                    Click="GemFilterAll_OnClick"/>
                            <Button x:Name="GemFilterOffensiveButton"
                                    Content="Offensiv"
                                    Click="GemFilterOffensive_OnClick"/>
                            <Button x:Name="GemFilterDefensiveButton"
                                    Content="Defensiv"
                                    Click="GemFilterDefensive_OnClick"/>
                            <Button x:Name="GemFilterOpalButton"
                                    Content="Opal"
                                    Click="GemFilterOpal_OnClick"/>
                            <Button x:Name="GemFilterDiamondsButton"
                                    Content="Diamanten"
                                    Click="GemFilterDiamonds_OnClick"/>
                            </StackPanel>

                            <CheckBox x:Name="CascadeGemTiersCheckBox"
                                      Grid.Column="1"
                                      Content="Hohe Stufe auf alle niedrigeren Stufen übernehmen"
                                      IsChecked="True"
                                      Foreground="White"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Margin="12,0,4,0"
                                      ToolTip="Beispiel: 9 bei Trapez trägt auch bei allen höheren Stufen 9 ein."/>
                        </Grid>

                        <ItemsControl x:Name="GemCardsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="6"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#111824"
                                            BorderThickness="1.5">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{Binding ColorHex}"/>
                                        </Border.BorderBrush>

                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="54"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="54"
                                                        Height="54"
                                                        CornerRadius="7"
                                                        Background="#17130D"
                                                        BorderBrush="#776A4E"
                                                        BorderThickness="1"
                                                        Padding="2">
                                                    <Image Source="{Binding ImagePath, Mode=OneWay}"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding GemName}"
                                                               Foreground="White"
                                                               FontSize="18"
                                                               FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding ColorName}"
                                                               Foreground="#9FB8E5"
                                                               FontSize="12"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="Gesamt: " Foreground="#7F91AC" FontSize="11"/>
                                                        <TextBlock Text="{Binding TotalQuantity, Mode=OneWay}"
                                                                   Foreground="White" FontWeight="Bold" FontSize="11"/>
                                                        <TextBlock Text="  ·  Maximal: " Foreground="#7F91AC" FontSize="11"/>
                                                        <TextBlock Text="{Binding MaximumQuantity, Mode=OneWay}"
                                                                   Foreground="#55D6C2" FontWeight="Bold" FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Tiers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
