                                    <TextBlock x:Name="VarnokDreamMissingText"
                                               Foreground="#FF5578"
                                               FontSize="27"
                                               FontWeight="Bold"
                                               Margin="0,7,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Heilige Sterne benötigt"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="VarnokStarRequiredText"
                                               Foreground="#FFD34F"
                                               FontSize="27"
                                               FontWeight="Bold"
                                               Margin="0,7,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Heilige Sterne fehlen"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="VarnokStarMissingText"
                                               Foreground="#FF5578"
                                               FontSize="27"
                                               FontWeight="Bold"
                                               Margin="0,7,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

