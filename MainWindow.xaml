                                             FontSize="20"
                                             TextChanged="MortisInput_OnChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Aktuelle Knochen"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBox x:Name="MortisCurrentBox"
                                             FontSize="20"
                                             TextChanged="MortisInput_OnChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Geplante Knochen"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="MortisPlannedBonesText"
                                               Foreground="#9B7BFF"
                                               FontSize="27"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Noch fehlend"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="MortisMissingBonesText"
                                               Foreground="#FF5578"
                                               FontSize="27"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Kosten -->
                        <Grid Margin="0,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Andermant je Eingang"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBox x:Name="MortisAndermantBox"
                                             TextChanged="MortisInput_OnChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Mortis-Münzen"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBox x:Name="MortisCoinsBox"
                                             TextChanged="MortisInput_OnChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Andermantkosten gesamt"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="MortisAndermantCostText"
                                               Foreground="#55D6C2"
                                               FontSize="23"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Bosskarten -->
                        <Grid Margin="6,12,6,6">
                            <TextBlock Text="BGH-Runs"
                                       Foreground="White"
                                       FontSize="23"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Die Zahl kann direkt eingetippt oder mit − / + geändert werden."
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"/>
                        </Grid>

                        <ItemsControl x:Name="MortisCardsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="6"
                                            Padding="14"
                                            CornerRadius="12"
                                            Background="#111824"
                                            BorderBrush="#8061F1"
                                            BorderThickness="1.5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="White"
                                                       FontSize="19"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center"/>

                                            <TextBlock Text="{Binding Difficulty}"
                                                       Foreground="#9FB8E5"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       Margin="0,3,0,12"/>

                                            <TextBlock HorizontalAlignment="Center"
                                                       Foreground="{StaticResource MutedBrush}">
                                                <Run Text="{Binding BonesPerRun}"/>
                                                <Run Text=" Knochen pro Run"/>
                                            </TextBlock>

                                            <Grid Margin="0,14,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="44"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="−"
                                                        FontSize="20"
                                                        Padding="0"
                                                        Tag="{Binding}"
                                                        Click="MortisRunMinus_OnClick"/>

                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Runs, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="{Binding}"
                                                         TextAlignment="Center"
                                                         VerticalContentAlignment="Center"
                                                         Foreground="White"
                                                         Background="#07101C"
                                                         BorderBrush="#2B374B"
                                                         BorderThickness="1"
                                                         FontSize="22"
                                                         FontWeight="Bold"
                                                         Margin="5,2"
                                                         Padding="3"
                                                         ToolTip="Runs direkt eingeben"
                                                         GotKeyboardFocus="QuantityTextBox_OnGotKeyboardFocus"
                                                         PreviewKeyDown="QuantityTextBox_OnPreviewKeyDown"
                                                         TextChanged="MortisRunTextBox_OnChanged"/>

                                                <Button Grid.Column="2"
                                                        Content="+"
                                                        FontSize="20"
                                                        Padding="0"
                                                        Background="{StaticResource AccentBrush}"
                                                        Tag="{Binding}"
                                                        Click="MortisRunPlus_OnClick"/>
                                            </Grid>

                                            <Separator Background="#2B374B"
                                                       Margin="0,5,0,8"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="Knochen"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding TotalBones, Mode=OneWay}"
                                                               Foreground="White"
                                                               FontSize="17"
                                                               FontWeight="Bold"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            HorizontalAlignment="Right">
                                                    <TextBlock Text="Eingänge"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding Entries}"
                                                               Foreground="White"
                                                               FontSize="17"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Elixierrechner -->
                        <TextBlock Text="Mortis-Knochenelixier"
                                   Foreground="White"
                                   FontSize="23"
                                   FontWeight="Bold"
                                   Margin="6,18,6,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Geplante Mortis-Runs"
                                                   Foreground="{StaticResource MutedBrush}"/>
                                        <TextBox x:Name="ElixirPlannedRunsBox"
                                                 TextChanged="MortisInput_OnChanged"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Runs je 15-Min.-Elixier"
                                                   Foreground="{StaticResource MutedBrush}"/>
                                        <TextBox x:Name="RunsPerElixirBox"
                                                 TextChanged="MortisInput_OnChanged"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Benötigte Elixiere"
                                                   Foreground="{StaticResource MutedBrush}"/>
                                        <TextBlock x:Name="RequiredElixirsText"
                                                   Foreground="#55D6C2"
                                                   FontSize="27"
                                                   FontWeight="Bold"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="3"
                                               Text="Ein Mortis-Knochenelixier hält 15 Minuten. Trage ein, wie viele Mortis-Runs du planst und wie viele Runs du durchschnittlich während eines Buffs schaffst."
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap"
                                               Margin="4,12,4,0"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Zusammenfassung"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Margin="0,0,0,10"/>

                                    <TextBlock x:Name="MortisCompactSummaryText"
                                               Foreground="White"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Fortschritt -->
                        <Border Style="{StaticResource CardStyle}" Margin="6,14,6,8">
                            <StackPanel>
                                <ProgressBar x:Name="MortisProgressBar"
                                             Height="22"
                                             Minimum="0"
                                             Maximum="100"
                                             Margin="0,0,0,10"/>
                                <TextBlock x:Name="MortisSummaryText"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>


                <!-- Varnok -->
                <ScrollViewer x:Name="VarnokPage"
                              Visibility="Collapsed"
                              Background="{StaticResource BackgroundBrush}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Varnok"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Fortschritt für das Varnok-Set – Werte exakt nach deiner Excel."
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,4,0,14"/>

                        <!-- Overview -->
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Traumschleier benötigt"
                                               Foreground="{StaticResource MutedBrush}"/>
