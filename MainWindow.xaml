                                    <TextBlock Text="Benötigter Runenstaub" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="RuneNeededDustText" Foreground="#9B7BFF"
                                               FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Fehlender Runenstaub" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="RuneMissingDustText" Foreground="#FF5578"
                                               FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Benötigtes Gold" Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="RuneNeededGoldText" Foreground="#FFD34F"
                                               FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
