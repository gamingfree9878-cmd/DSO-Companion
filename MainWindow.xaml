<Window x:Class="DSOCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DSO Companion"
        Width="1100"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0B1019"
                BorderBrush="#2B374B"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="20">
                <TextBlock Text="⚒ DSO Companion"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,24"/>

                <Button Content="🏠 Übersicht"
                        Height="46"
                        Margin="0,0,0,8"
                        Background="{StaticResource AccentBrush}"
                        Foreground="White"/>

                <Button Content="💎 Edelsteine"
                        Height="46"
                        Margin="0,0,0,8"
                        Background="{StaticResource PanelBrush}"
                        Foreground="White"/>

                <Button Content="ᚱ Runen"
                        Height="46"
                        Margin="0,0,0,8"
                        Background="{StaticResource PanelBrush}"
                        Foreground="White"/>

                <Button Content="🔷 Juwelen"
                        Height="46"
                        Margin="0,0,0,8"
                        Background="{StaticResource PanelBrush}"
                        Foreground="White"/>

                <Button Content="🦴 Mortis / BGH"
                        Height="46"
                        Background="{StaticResource PanelBrush}"
                        Foreground="White"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="DSO Companion"
                           FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Sauberer Neustart – Version 0.0.1"
                           FontSize="18"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>

                <Border Background="{StaticResource PanelBrush}"
                        CornerRadius="14"
                        Padding="24"
                        Margin="0,32,0,0"
                        MaxWidth="620"
                        HorizontalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Der automatische Windows-Build ist eingerichtet."
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"/>

                        <TextBlock Text="Sobald GitHub Actions grün ist, ergänzen wir nacheinander Profile, Builds, Edelsteine, Runen, Juwelen und Mortis."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,12,0,0"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
