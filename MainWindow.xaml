                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="MortisPage"
                              Visibility="Collapsed"
                              Background="{StaticResource BackgroundBrush}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Mortis / BGH"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Runs planen, Knochen berechnen und den Bedarf an Mortis-Knochenelixieren ermitteln."
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,4,0,14"/>

                        <!-- Hauptwerte -->
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Ziel-Knochen"
                                               Foreground="{StaticResource MutedBrush}"/>
