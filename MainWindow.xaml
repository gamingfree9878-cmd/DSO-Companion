                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="2,6,2,8">
                            <Button x:Name="RuneFilterAllButton" Content="Alle"
                                    Background="{StaticResource AccentBrush}"
                                    Click="RuneFilterAll_OnClick"/>
                            <Button x:Name="RuneFilterOffensiveButton" Content="Offensiv"
                                    Click="RuneFilterOffensive_OnClick"/>
                            <Button x:Name="RuneFilterDefensiveButton" Content="Defensiv"
                                    Click="RuneFilterDefensive_OnClick"/>
                            <Button x:Name="RuneFilterOtherButton" Content="Sonstige"
                                    Click="RuneFilterOther_OnClick"/>
                        </StackPanel>

                        <ItemsControl x:Name="RuneCardsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="6" Padding="12" CornerRadius="12"
                                            Background="#111824" BorderBrush="#8061F1" BorderThickness="1.5">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="62"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="54" Height="54" CornerRadius="7"
                                                        Background="#17130D" BorderBrush="#776A4E"
                                                        BorderThickness="1" Padding="2">
                                                    <Image Source="{Binding ImagePath, Mode=OneWay}"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding RuneName}" Foreground="White"
                                                               FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Category}" Foreground="#9FB8E5"
                                                               FontSize="12"/>
                                                </StackPanel>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Tiers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="32"/>
                                                                <ColumnDefinition Width="42"/>
                                                                <ColumnDefinition Width="32"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding TierName}" Foreground="White"
                                                                           FontWeight="Bold"/>
                                                                <TextBlock Foreground="#8CB4E8" FontSize="10">
                                                                    <Run Text="{Binding DustCost, StringFormat={}{0:N0}}"/>
                                                                    <Run Text=" Staub · "/>
                                                                    <Run Text="{Binding GoldCost, StringFormat={}{0:N0}}"/>
                                                                    <Run Text=" Gold"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Content="−" Padding="0" Margin="2"
                                                                    Tag="{Binding}" Click="RuneCardMinus_OnClick"/>
                                                            <TextBox Grid.Column="2"
                                                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                                     Tag="{Binding}"
                                                                     TextAlignment="Center"
                                                                     VerticalContentAlignment="Center"
                                                                     FontWeight="Bold"
                                                                     Background="#07101C"
                                                                     Foreground="White"
                                                                     BorderBrush="#2B374B"
                                                                     BorderThickness="1"
                                                                     Margin="2"
                                                                     Padding="2"
                                                                     ToolTip="Besitz direkt eingeben"
                                                                     GotKeyboardFocus="QuantityTextBox_OnGotKeyboardFocus"
                                                                     PreviewKeyDown="QuantityTextBox_OnPreviewKeyDown"
                                                                     TextChanged="RuneQuantityTextBox_OnChanged"/>
                                                            <Button Grid.Column="3" Content="+" Padding="0" Margin="2"
                                                                    Background="{StaticResource AccentBrush}"
                                                                    Tag="{Binding}" Click="RuneCardPlus_OnClick"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Separator Background="#2B374B" Margin="0,8,0,6"/>
                                            <Grid>
                                                <TextBlock Foreground="#9FB8E5">
                                                    <Run Text="Staub: "/>
                                                    <Run Text="{Binding TotalDust, Mode=OneWay, StringFormat={}{0:N0}}"
                                                         Foreground="White" FontWeight="Bold"/>
                                                </TextBlock>
                                                <TextBlock HorizontalAlignment="Right" Foreground="#9FB8E5">
                                                    <Run Text="Gold: "/>
                                                    <Run Text="{Binding TotalGold, Mode=OneWay, StringFormat={}{0:N0}}"
                                                         Foreground="White" FontWeight="Bold"/>
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="JewelsPage" Visibility="Collapsed" Background="{StaticResource BackgroundBrush}">
