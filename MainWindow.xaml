<Window x:Class="DSOCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DSO Companion"
        Width="1450"
        Height="900"
        MinWidth="1150"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="20">
                <TextBlock Text="⚒ DSO Companion"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,24"/>

                <Button x:Name="DashboardButton"
                        Content="🏠 Übersicht"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="DashboardButton_OnClick"/>

                <Button x:Name="CharactersButton"
                        Content="👤 Charaktere &amp; Builds"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="CharactersButton_OnClick"/>

                <Button x:Name="EquipmentButton"
                        Content="⚔ Ausrüstung"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="EquipmentButton_OnClick"/>

                <Button x:Name="GemsButton"
                        Content="💎 Edelsteine"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="GemsButton_OnClick"/>

                <Button x:Name="RunesButton"
                        Content="ᚱ Runen"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="RunesButton_OnClick"/>

                <Button x:Name="JewelsButton"
                        Content="🔷 Juwelen"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="JewelsButton_OnClick"/>

                <Button x:Name="MortisButton"
                        Content="🦴 Mortis / BGH"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="MortisButton_OnClick"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Margin="24"
              Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Charakter:"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="4"/>

                    <ComboBox x:Name="CharacterCombo"
                              Grid.Column="1"
                              DisplayMemberPath="Name"
                              SelectionChanged="CharacterCombo_OnSelectionChanged"/>

                    <Button Grid.Column="2"
                            Content="+ Charakter"
                            Background="{StaticResource AccentBrush}"
                            Click="AddCharacter_OnClick"/>

                    <Button Grid.Column="3"
                            Content="Umbenennen"
                            Click="RenameCharacter_OnClick"/>

                    <Button Grid.Column="4"
                            Content="Löschen"
                            Background="{StaticResource DangerBrush}"
                            Click="DeleteCharacter_OnClick"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="6,10,6,6">

                <!-- Dashboard -->
                <ScrollViewer x:Name="DashboardPage"
                              Background="{StaticResource BackgroundBrush}"
                              Visibility="Visible">
                    <StackPanel Margin="12">
                        <TextBlock Text="Übersicht"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Margin="6,4,6,4"/>

                        <TextBlock Text="Dein DSO-Begleiter auf einen Blick."
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="6,0,6,18"/>

                        <UniformGrid Columns="3">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="👤 Aktiver Charakter"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="DashboardCharacterText"
                                               Foreground="White"
                                               FontSize="25"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="⚔ Aktiver Build"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="DashboardBuildText"
                                               Foreground="White"
                                               FontSize="23"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="📦 Gespeicherte Builds"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="DashboardBuildCountText"
                                               Foreground="White"
                                               FontSize="25"
                                               FontWeight="Bold"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource CardStyle}" Margin="6,18,6,6">
                            <StackPanel>
                                <TextBlock Text="Willkommen im DSO Companion"
                                           Foreground="White"
                                           FontSize="24"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Über das Menü links erreichst du jetzt alle Bereiche. Charaktere, Builds und Ausrüstung sind bereits nutzbar. Die Rechner für Edelsteine, Runen, Juwelen und Mortis werden in den nächsten Versionen auf ihren eigenen Seiten ergänzt."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Characters -->
                <ScrollViewer x:Name="CharactersPage"
                              Background="{StaticResource BackgroundBrush}"
                              Visibility="Collapsed">
                    <StackPanel Margin="12">
                        <TextBlock Text="Charakterverwaltung"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Margin="6,4,6,4"/>

                        <TextBlock Text="Profile, Builds und Ausrüstung werden automatisch lokal gespeichert."
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="6,0,6,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="390"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="👤 Charakterdaten"
                                               Foreground="White"
                                               FontSize="21"
                                               FontWeight="Bold"
                                               Margin="4,0,4,12"/>

                                    <TextBlock Text="Name" Foreground="{StaticResource MutedBrush}" Margin="4"/>
                                    <TextBox x:Name="CharacterNameBox"
                                             TextChanged="CharacterField_OnChanged"/>

                                    <TextBlock Text="Klasse" Foreground="{StaticResource MutedBrush}" Margin="4,10,4,4"/>
                                    <ComboBox x:Name="ClassCombo"
                                              SelectionChanged="CharacterField_OnChanged"/>

                                    <TextBlock Text="Level" Foreground="{StaticResource MutedBrush}" Margin="4,10,4,4"/>
                                    <TextBox x:Name="LevelBox"
                                             TextChanged="CharacterField_OnChanged"/>

                                    <TextBlock Text="Server" Foreground="{StaticResource MutedBrush}" Margin="4,10,4,4"/>
                                    <ComboBox x:Name="ServerCombo"
                                              SelectionChanged="CharacterField_OnChanged"/>

                                    <TextBlock Text="Notizen" Foreground="{StaticResource MutedBrush}" Margin="4,10,4,4"/>
                                    <TextBox x:Name="CharacterNotesBox"
                                             Height="100"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="CharacterField_OnChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="⚔ Builds"
                                               Foreground="White"
                                               FontSize="21"
                                               FontWeight="Bold"
                                               Margin="4,0,4,12"/>

                                    <WrapPanel Grid.Row="1">
                                        <Button Content="+ Build"
                                                Background="{StaticResource AccentBrush}"
                                                Click="AddBuild_OnClick"/>
                                        <Button Content="Umbenennen"
                                                Click="RenameBuild_OnClick"/>
                                        <Button Content="Kopieren"
                                                Click="CopyBuild_OnClick"/>
                                        <Button Content="Löschen"
                                                Background="{StaticResource DangerBrush}"
                                                Click="DeleteBuild_OnClick"/>
                                    </WrapPanel>

                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                Margin="4,8,4,8">
                                        <TextBlock Text="Build-Typ:"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <ComboBox x:Name="BuildTypeCombo"
                                                  Width="180"
                                                  SelectionChanged="BuildTypeCombo_OnSelectionChanged"/>
                                    </StackPanel>

                                    <ListBox x:Name="BuildList"
                                             Grid.Row="3"
                                             DisplayMemberPath="Name"
                                             SelectionChanged="BuildList_OnSelectionChanged"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <UniformGrid Columns="3" Margin="0,10,0,0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="👤 Aktiver Charakter"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="SummaryCharacterText"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="⚔ Klasse &amp; Server"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="SummaryClassText"
                                               Foreground="White"
                                               FontSize="19"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="📦 Builds"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="SummaryBuildCountText"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Equipment -->
                <Grid x:Name="EquipmentPage"
                      Background="{StaticResource BackgroundBrush}"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Ausrüstung des Builds:"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="4"/>
                                <TextBlock x:Name="ActiveBuildHeader"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="8,4"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="Gegenstand aus der Bibliothek auf einen Slot ziehen"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="8"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="230"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Item library -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="DSOFUN-Itembibliothek"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Margin="4,0,4,10"/>

                                <TextBox x:Name="ItemSearchBox"
                                         Grid.Row="1"
                                         ToolTip="Nach Name, Slot oder Seltenheit suchen"
                                         TextChanged="ItemSearchBox_OnTextChanged"/>

                                <ListBox x:Name="ItemLibraryList"
                                         Grid.Row="2"
                                         PreviewMouseLeftButtonDown="ItemLibraryList_OnPreviewMouseLeftButtonDown"
                                         PreviewMouseMove="ItemLibraryList_OnPreviewMouseMove"
                                         SelectionChanged="ItemLibraryList_OnSelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="3"
                                                    Padding="10"
                                                    Background="#111824"
                                                    BorderBrush="#8061F1"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="15"
                                                               FontWeight="Bold"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               Foreground="#9FB8E5"
                                                               FontSize="11"
                                                               Margin="0,3,0,0"/>
                                                    <TextBlock Text="{Binding ItemType}"
                                                               Foreground="#99A9C0"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Button Grid.Row="3"
                                        Content="Ausgewähltes Item übernehmen"
                                        Background="{StaticResource AccentBrush}"
                                        Click="ApplySelectedItem_OnClick"/>
                            </Grid>
                        </Border>

                        <!-- Equipment slots -->
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Ausrüstungsslots"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Margin="4,0,4,12"/>
                                <TextBlock Text="Hierhin ziehen:"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="4,0,4,6"/>
                                <ListBox x:Name="EquipmentSlotList"
                                         DisplayMemberPath="SlotName"
                                         AllowDrop="True"
                                         DragOver="EquipmentSlotList_OnDragOver"
                                         Drop="EquipmentSlotList_OnDrop"
                                         SelectionChanged="EquipmentSlotList_OnSelectionChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Item editor -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <ScrollViewer>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="175"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.ColumnSpan="2"
                                               x:Name="SelectedSlotHeader"
                                               Text="Ausrüstung"
                                               Foreground="White"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Margin="4,0,4,14"/>

                                    <TextBlock Grid.Row="1" Text="Itemname" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="ItemNameBox" Grid.Row="1" Grid.Column="1" TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="2" Text="Seltenheit / Typ" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="RarityTypeBox" Grid.Row="2" Grid.Column="1" IsReadOnly="True"/>

                                    <TextBlock Grid.Row="3" Text="Gegenstandsstufe" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="ItemLevelBox" Grid.Row="3" Grid.Column="1" TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="4" Text="Basiswerte" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="BaseValuesBox" Grid.Row="4" Grid.Column="1" Height="75"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="5" Text="Einzigartige Werte" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="EnchantmentsBox" Grid.Row="5" Grid.Column="1" Height="120"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="6" Text="Setbonus" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="SetBonusBox" Grid.Row="6" Grid.Column="1" Height="70"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="7" Text="Fundort" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="ObtainableFromBox" Grid.Row="7" Grid.Column="1" Height="55"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="8" Text="Edelsteine" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="GemsBox" Grid.Row="8" Grid.Column="1" Height="60"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="9" Text="Runen" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="RunesBox" Grid.Row="9" Grid.Column="1" Height="55"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="10" Text="Juwel" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="JewelBox" Grid.Row="10" Grid.Column="1" TextChanged="EquipmentField_OnChanged"/>

                                    <TextBlock Grid.Row="11" Text="Quelle" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="SourceUrlBox" Grid.Row="11" Grid.Column="1" IsReadOnly="True"/>

                                    <TextBlock Grid.Row="12" Text="Notizen" Foreground="{StaticResource MutedBrush}" Margin="8"/>
                                    <TextBox x:Name="EquipmentNotesBox" Grid.Row="12" Grid.Column="1" Height="75"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="EquipmentField_OnChanged"/>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Placeholder pages -->
                <ScrollViewer x:Name="GemsPage"
                              Visibility="Collapsed"
                              Background="{StaticResource BackgroundBrush}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Edelsteine"
                                           Foreground="White"
                                           FontSize="30"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Jede Sorte wird unabhängig berechnet."
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="+ Profil"
                                        Background="{StaticResource AccentBrush}"
                                        Click="AddCharacter_OnClick"/>
                                <Button Content="Umbenennen"
                                        Click="RenameCharacter_OnClick"/>
                                <Button Content="Löschen"
                                        Background="{StaticResource DangerBrush}"
                                        Click="DeleteCharacter_OnClick"/>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Columns="4" Margin="0,14,0,0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Benötigter Staub"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="GemNeededDustText"
                                               Foreground="#9B7BFF"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Noch fehlender Staub"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="GemMissingDustText"
                                               Foreground="#FF5578"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Benötigtes Gold"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="GemNeededGoldText"
                                               Foreground="#FFD34F"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Noch fehlendes Gold"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBlock x:Name="GemMissingGoldText"
                                               Foreground="#FF5578"
                                               FontSize="26"
                                               FontWeight="Bold"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource CardStyle}" Margin="6,10,6,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Vorhandener funkelnder Staub"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBox x:Name="OwnedGemDustBox"
                                             TextChanged="GemResource_OnChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Vorhandenes Gold"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <TextBox x:Name="OwnedGoldBox"
                                             TextChanged="GemResource_OnChanged"/>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="Edelsteine leeren"
                                        Background="{StaticResource DangerBrush}"
                                        VerticalAlignment="Bottom"
                                        Margin="8,4"
                                        Click="ClearAllGems_OnClick"/>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="2,6,2,8">
                            <Button x:Name="GemFilterAllButton"
                                    Content="Alle"
                                    Background="{StaticResource AccentBrush}"
                                    Click="GemFilterAll_OnClick"/>
                            <Button x:Name="GemFilterOffensiveButton"
                                    Content="Offensiv"
                                    Click="GemFilterOffensive_OnClick"/>
                            <Button x:Name="GemFilterDefensiveButton"
                                    Content="Defensiv"
                                    Click="GemFilterDefensive_OnClick"/>
                            <Button x:Name="GemFilterOpalButton"
                                    Content="Opal"
                                    Click="GemFilterOpal_OnClick"/>
                            <Button x:Name="GemFilterDiamondsButton"
                                    Content="Diamanten"
                                    Click="GemFilterDiamonds_OnClick"/>
                        </StackPanel>

                        <ItemsControl x:Name="GemCardsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="6"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#111824"
                                            BorderThickness="1.5">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{Binding ColorHex}"/>
                                        </Border.BorderBrush>

                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="54"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="54"
                                                        Height="54"
                                                        CornerRadius="7"
                                                        Background="#17130D"
                                                        BorderBrush="#776A4E"
                                                        BorderThickness="1"
                                                        Padding="2">
                                                    <Image Source="{Binding ImagePath, Mode=OneWay}"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding GemName}"
                                                               Foreground="White"
                                                               FontSize="18"
                                                               FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding ColorName}"
                                                               Foreground="#9FB8E5"
                                                               FontSize="12"/>
                                                </StackPanel>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Tiers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="32"/>
                                                                <ColumnDefinition Width="42"/>
                                                                <ColumnDefinition Width="32"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="{Binding TierName}"
                                                                           Foreground="White"
                                                                           FontWeight="Bold"
                                                                           FontSize="14"/>
                                                                <TextBlock Foreground="#8CB4E8"
                                                                           FontSize="10">
                                                                    <Run Text="{Binding DustCost, StringFormat={}{0:N0}}"/>
                                                                    <Run Text=" Staub · "/>
                                                                    <Run Text="{Binding GoldCost, StringFormat={}{0:N0}}"/>
                                                                    <Run Text=" Gold"/>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <Button Grid.Column="1"
                                                                    Content="−"
                                                                    Padding="0"
                                                                    Margin="2"
                                                                    Tag="{Binding}"
                                                                    Click="GemCardMinus_OnClick"/>

                                                            <Border Grid.Column="2"
                                                                    Background="#07101C"
                                                                    BorderBrush="#2B374B"
                                                                    BorderThickness="1"
                                                                    CornerRadius="7"
                                                                    Margin="2">
                                                                <TextBlock Text="{Binding Quantity}"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>

                                                            <Button Grid.Column="3"
                                                                    Content="+"
                                                                    Padding="0"
                                                                    Margin="2"
                                                                    Background="{StaticResource AccentBrush}"
                                                                    Tag="{Binding}"
                                                                    Click="GemCardPlus_OnClick"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Separator Background="#2B374B" Margin="0,8,0,6"/>

                                            <Grid>
                                                <TextBlock Foreground="#9FB8E5">
                                                    <Run Text="Staub: "/>
                                                    <Run Text="{Binding TotalDust, Mode=OneWay, StringFormat={}{0:N0}}"
                                                         Foreground="White"
                                                         FontWeight="Bold"/>
                                                </TextBlock>
                                                <TextBlock HorizontalAlignment="Right"
                                                           Foreground="#9FB8E5">
                                                    <Run Text="Gold: "/>
                                                    <Run Text="{Binding TotalGold, Mode=OneWay, StringFormat={}{0:N0}}"
                                                         Foreground="White"
                                                         FontWeight="Bold"/>
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="RunesPage" Visibility="Collapsed" Background="{StaticResource BackgroundBrush}">
                    <StackPanel Margin="18">
                        <TextBlock Text="ᚱ Runen"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Der getrennte Runenrechner wird auf dieser Seite eingebaut."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="16"
                                   Margin="0,8,0,20"/>
                        <Border Style="{StaticResource CardStyle}">
                            <TextBlock Text="Vorbereitet für offensive, defensive und sonstige Runen mit eigenen Stufen und Staubkosten."
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       FontSize="18"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="JewelsPage" Visibility="Collapsed" Background="{StaticResource BackgroundBrush}">
                    <StackPanel Margin="18">
                        <TextBlock Text="🔷 Juwelen"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Bilder, deutsche Namen, Wirkungen und Einbauplätze kommen auf diese Seite."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="16"
                                   Margin="0,8,0,20"/>
                        <Border Style="{StaticResource CardStyle}">
                            <TextBlock Text="Die Juwelen werden später durchsucht, gefiltert und den Ausrüstungsslots zugeordnet."
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       FontSize="18"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="MortisPage" Visibility="Collapsed" Background="{StaticResource BackgroundBrush}">
                    <StackPanel Margin="18">
                        <TextBlock Text="🦴 Mortis / BGH"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Der komplette Knochen-, Run-, Zeit- und Eingangsrechner wird hier eingebaut."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="16"
                                   Margin="0,8,0,20"/>
                        <UniformGrid Columns="3">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Mortis" Foreground="White" FontSize="21" FontWeight="Bold"/>
                                    <TextBlock Text="Infernal: 25&#x0a;Gnadenlos: 35&#x0a;Blutvergießen: 35"
                                               Foreground="{StaticResource MutedBrush}"
                                               Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Inferno" Foreground="White" FontSize="21" FontWeight="Bold"/>
                                    <TextBlock Text="Infernal: 40&#x0a;Gnadenlos: 50&#x0a;Blutvergießen: 60"
                                               Foreground="{StaticResource MutedBrush}"
                                               Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Wächter" Foreground="White" FontSize="21" FontWeight="Bold"/>
                                    <TextBlock Text="Wächter: 5&#x0a;Wächtergruppe: 25"
                                               Foreground="{StaticResource MutedBrush}"
                                               Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
