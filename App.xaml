<Application x:Class="DSOCompanion.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#080B12"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#111824"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#8061F1"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F3F6FB"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#99A9C0"/>
    </Application.Resources>
</Application>
